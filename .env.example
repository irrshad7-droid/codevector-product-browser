# Copy this file to `.env` and replace placeholder values.
# Never commit `.env` — it contains secrets.

# -----------------------------------------------------------------------------
# Database (Neon PostgreSQL)
# -----------------------------------------------------------------------------

# Prisma reads this from prisma/schema.prisma (datasource db).
#
# Neon gives two connection strings — pick based on what you're running:
#
# 1) DIRECT (no "-pooler" in hostname) — use for local `prisma migrate dev`
#    Example:
#    postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
#
# 2) POOLED ("-pooler" in hostname) — use for Render/runtime (many short connections)
#    Example:
#    postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require
#
# For first-time setup: start with the DIRECT URL here so migrations work reliably.
# Switch to POOLED on Render when you deploy the app.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# -----------------------------------------------------------------------------
# Application (used later by Express — safe to set now)
# -----------------------------------------------------------------------------

# HTTP port for the API server (Render often sets PORT automatically in production).
PORT=3000
